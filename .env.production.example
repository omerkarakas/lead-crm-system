# =============================================================================
# Moka CRM - Production Environment Variables Template
# =============================================================================
# Bu dosyayı kopyalayın ve değerlerinizi doldurun:
# cp .env.production.example .env.production
#
# Docker kullanıyorsanız, bu değerleri docker-compose.yml'da environment olarak
# veya .env dosyasında tanımlayın.
# =============================================================================

# ---------------------------------------------------------------------------
# Instance Configuration (Multi-Instance için)
# ---------------------------------------------------------------------------
INSTANCE_NAME=mokacrm
DOMAIN=crm.yourdomain.com

# ---------------------------------------------------------------------------
# PocketBase Configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POCKETBASE_URL=http://pocketbase:8090
# Not: Docker içindeyken pocketbase service adını kullanın
# Production'da dışarıdan erişim gerekiyorsa: https://pb.yourdomain.com

# PocketBase Data Path (Local volume mount)
PB_DATA_PATH=./pb_data
PB_PUBLIC_PATH=./pb_public

# ---------------------------------------------------------------------------
# Email Service (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Moka CRM

# ---------------------------------------------------------------------------
# WhatsApp API (Green API)
# ---------------------------------------------------------------------------
GREEN_API_INSTANCE_ID=123456789
GREEN_API_TOKEN=abc123def456xyz789

# ---------------------------------------------------------------------------
# Application Configuration
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ---------------------------------------------------------------------------
# OAuth Configuration (Optional - Future)
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# NEXTAUTH_URL=https://crm.yourdomain.com
# NEXTAUTH_SECRET=your-super-secret-key-min-32-chars

# ---------------------------------------------------------------------------
# Monitoring & Logging (Optional)
# ---------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
