{
  "collections": [
    {
      "id": "_pb_users_auth_",
      "name": "users",
      "type": "auth",
      "schema": [
        {
          "id": "users_name",
          "name": "name",
          "type": "text",
          "required": true,
          "options": {
            "min": 1,
            "max": 200
          }
        },
        {
          "id": "users_role",
          "name": "role",
          "type": "select",
          "required": true,
          "options": {
            "values": ["admin", "sales", "marketing"],
            "maxSelect": 1
          },
          "default": "sales"
        },
        {
          "id": "users_avatar",
          "name": "avatar",
          "type": "file",
          "required": false,
          "options": {
            "maxSelect": 1,
            "maxSize": 1048576,
            "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"]
          }
        }
      ]
    },
    {
      "id": "leads_collection",
      "name": "leads",
      "type": "base",
      "schema": [
        {
          "id": "leads_name",
          "name": "name",
          "type": "text",
          "required": true,
          "options": {
            "min": 1,
            "max": 200
          }
        },
        {
          "id": "leads_phone",
          "name": "phone",
          "type": "text",
          "required": true,
          "options": {
            "min": 1,
            "max": 50
          }
        },
        {
          "id": "leads_email",
          "name": "email",
          "type": "email",
          "required": false,
          "options": {}
        },
        {
          "id": "leads_company",
          "name": "company",
          "type": "text",
          "required": false,
          "options": {
            "min": 1,
            "max": 200
          }
        },
        {
          "id": "leads_website",
          "name": "website",
          "type": "url",
          "required": false,
          "options": {}
        },
        {
          "id": "leads_message",
          "name": "message",
          "type": "text",
          "required": false,
          "options": {
            "min": 1,
            "max": 5000
          }
        },
        {
          "id": "leads_source",
          "name": "source",
          "type": "select",
          "required": true,
          "options": {
            "values": ["web_form", "api", "manual", "whatsapp"],
            "maxSelect": 1
          },
          "default": "manual"
        },
        {
          "id": "leads_status",
          "name": "status",
          "type": "select",
          "required": true,
          "options": {
            "values": ["new", "qualified", "booked", "customer", "lost"],
            "maxSelect": 1
          },
          "default": "new"
        },
        {
          "id": "leads_score",
          "name": "score",
          "type": "number",
          "required": true,
          "options": {
            "min": 0,
            "max": 100
          },
          "default": 0
        },
        {
          "id": "leads_quality",
          "name": "quality",
          "type": "select",
          "required": true,
          "options": {
            "values": ["pending", "qualified"],
            "maxSelect": 1
          },
          "default": "pending"
        },
        {
          "id": "leads_tags",
          "name": "tags",
          "type": "text[]",
          "required": false,
          "options": {}
        },
        {
          "id": "leads_createdBy",
          "name": "createdBy",
          "type": "relation",
          "required": false,
          "options": {
            "collectionId": "_pb_users_auth_",
            "cascadeDelete": false,
            "minSelect": 0,
            "maxSelect": 1
          }
        }
      ]
    },
    {
      "id": "notes_collection",
      "name": "notes",
      "type": "base",
      "schema": [
        {
          "id": "notes_leadId",
          "name": "leadId",
          "type": "relation",
          "required": true,
          "options": {
            "collectionId": "leads_collection",
            "cascadeDelete": true,
            "minSelect": 1,
            "maxSelect": 1
          }
        },
        {
          "id": "notes_userId",
          "name": "userId",
          "type": "relation",
          "required": true,
          "options": {
            "collectionId": "_pb_users_auth_",
            "cascadeDelete": false,
            "minSelect": 1,
            "maxSelect": 1
          }
        },
        {
          "id": "notes_content",
          "name": "content",
          "type": "text",
          "required": true,
          "options": {
            "min": 1,
            "max": 5000
          }
        }
      ]
    },
    {
      "id": "tags_collection",
      "name": "tags",
      "type": "base",
      "schema": [
        {
          "id": "tags_name",
          "name": "name",
          "type": "text",
          "required": true,
          "options": {
            "min": 1,
            "max": 100
          },
          "unique": true
        },
        {
          "id": "tags_color",
          "name": "color",
          "type": "text",
          "required": false,
          "options": {
            "min": 1,
            "max": 7
          }
        }
      ]
    },
    {
      "id": "sessions_collection",
      "name": "sessions",
      "type": "base",
      "schema": [
        {
          "id": "sessions_userId",
          "name": "userId",
          "type": "relation",
          "required": true,
          "options": {
            "collectionId": "_pb_users_auth_",
            "cascadeDelete": true,
            "minSelect": 1,
            "maxSelect": 1
          }
        },
        {
          "id": "sessions_deviceName",
          "name": "deviceName",
          "type": "text",
          "required": false,
          "options": {
            "min": 1,
            "max": 200
          }
        },
        {
          "id": "sessions_deviceType",
          "name": "deviceType",
          "type": "select",
          "required": true,
          "options": {
            "values": ["desktop", "mobile", "tablet"],
            "maxSelect": 1
          },
          "default": "desktop"
        },
        {
          "id": "sessions_ipAddress",
          "name": "ipAddress",
          "type": "text",
          "required": false,
          "options": {
            "min": 1,
            "max": 50
          }
        },
        {
          "id": "sessions_userAgent",
          "name": "userAgent",
          "type": "text",
          "required": false,
          "options": {
            "min": 1,
            "max": 500
          }
        }
      ]
    },
    {
      "id": "qa_questions_collection",
      "name": "qa_questions",
      "type": "base",
      "schema": [
        {
          "id": "qa_questions_question_text",
          "name": "question_text",
          "type": "text",
          "required": true,
          "options": {
            "min": 1,
            "max": 500
          }
        },
        {
          "id": "qa_questions_options",
          "name": "options",
          "type": "json",
          "required": true,
          "options": {}
        },
        {
          "id": "qa_questions_points",
          "name": "points",
          "type": "json",
          "required": true,
          "options": {}
        },
        {
          "id": "qa_questions_order",
          "name": "order",
          "type": "number",
          "required": true,
          "options": {
            "min": 0,
            "max": 1000
          },
          "default": 0
        },
        {
          "id": "qa_questions_is_active",
          "name": "is_active",
          "type": "bool",
          "required": true,
          "options": {},
          "default": true
        }
      ]
    }
  ]
}
