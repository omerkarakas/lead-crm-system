    {
      "parameters": {
        "jsCode": "// Format confirmation message\nconst lead = $('Find Lead by Email').first().json;\nconst booking = $('Extract Booking Info').first().json;\n\nconst leadName = lead.name || 'Degerli Musterimiz';\nconst leadPhone = lead.phone.toString();\n\n// Format date for Turkish locale\nconst startDate = new Date(booking.startTime);\nconst options = { \n  weekday: 'long', \n  year: 'numeric', \n  month: 'long', \n  day: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit',\n  timeZone: 'Europe/Istanbul'\n};\n\nconst formattedDate = startDate.toLocaleDateString('tr-TR', options);\n\nconst message = `Randevunuz onaylandı!\\n\\nTarih: ${formattedDate}\\nSure: ${booking.durationMinutes} dakika\\nToplanti: Online\\n\\nToplanti linki: ${booking.meetingUrl || 'Mail ile gonderilecek'}\\n\\nToplantiyi takviminizde isaretlemeyi unutmayin.\\n\\nToplantiya ustteki linke tiklayarak katilirken bir bilgisayar kullaniyor olmaniz daha verimli olacaktir.\\n\\nGorusmek uzere!`;\n\n// Format phone for Green API\nconst chatId = leadPhone.replace(/\\D/g, '') + '@c.us';\n\nreturn {\n  json: {\n    chatId: chatId,\n    message: message,\n    leadId: lead.id,\n    leadName: leadName,\n    leadPhone: leadPhone\n  }\n};"
      },
