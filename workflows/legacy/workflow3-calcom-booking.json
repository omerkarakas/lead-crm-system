    {
      "parameters": {
        "jsCode": "// Extract booking info from Cal.com webhook\nconst webhookData = $('Cal.com Webhook').first().json;\n\n// Cal.com webhook payload structure\nconst payload = webhookData.body?.payload || webhookData.payload || {};\nconst triggerEvent = webhookData.body?.triggerEvent || webhookData.triggerEvent || '';\n\n// Extract attendee info\nconst attendees = payload.attendees || [];\nconst attendee = attendees[0] || {};\n\nconst attendeeEmail = attendee.email || '';\nconst attendeeName = attendee.name || '';\n\n// Extract booking details (UTC from Cal.com)\nconst startTimeUTC = payload.startTime || '';\nconst endTimeUTC = payload.endTime || '';\nconst title = payload.title || '';\n\n// Convert to Istanbul timezone (GMT+3) for storage\nfunction toIstanbulISO(utcDateStr) {\n  if (!utcDateStr) return '';\n  const date = new Date(utcDateStr);\n  return date.toLocaleString('sv-SE', { timeZone: 'Europe/Istanbul' }).replace(' ', 'T') + '+03:00';\n}\n\nconst startTime = toIstanbulISO(startTimeUTC);\nconst endTime = toIstanbulISO(endTimeUTC);\n\n// Calculate duration in minutes\nlet durationMinutes = 30; // default\nif (startTimeUTC && endTimeUTC) {\n  const start = new Date(startTimeUTC);\n  const end = new Date(endTimeUTC);\n  durationMinutes = Math.round((end - start) / (1000 * 60));\n}\n\n// Get meeting URL\nconst metadata = payload.metadata || {};\nconst meetingUrl = metadata.videoCallUrl || payload.meetingUrl || '';\n\n// Get Cal.com event ID\nconst calcomEventId = payload.uid || payload.id || '';\n\nreturn {\n  json: {\n    triggerEvent: triggerEvent,\n    attendeeEmail: attendeeEmail,\n    attendeeName: attendeeName,\n    startTime: startTime,\n    endTime: endTime,\n    durationMinutes: durationMinutes,\n    title: title,\n    meetingUrl: meetingUrl,\n    calcomEventId: calcomEventId,\n    rawPayload: payload\n  }\n};"
      },
