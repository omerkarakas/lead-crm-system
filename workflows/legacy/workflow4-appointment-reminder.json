    {
      "parameters": {
        "jsCode": "// Format reminder message\nconst lead = $('Get Lead Info').first().json;\nconst appointment = $('Has Appointments?').first().json;\nconst env = $('ENV').first().json;\n\nconst leadName = lead.name || 'Degerli Musterimiz';\nconst leadPhone = lead.phone.toString();\n\n// Format date\nconst scheduledDate = new Date(appointment.scheduledAt);\nconst options = { \n  weekday: 'long', \n  year: 'numeric', \n  month: 'long', \n  day: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit',\n  timeZone: 'Europe/Istanbul'\n};\nconst formattedDate = scheduledDate.toLocaleDateString('tr-TR', options);\n\nconst message = `Randevu Hatirlatmasi\\n\\nMerhaba ${leadName}!\\n\\nYarin saat ${scheduledDate.toLocaleTimeString('tr-TR', {hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Istanbul'})}'de online gorusmemiz var.\\n\\nTarih: ${formattedDate}\\nLink: ${appointment.meetingUrl || 'Mail ile paylasilan'}\\n\\nGorusmek uzere!`;\n\n// Format phone for Green API\nconst chatId = leadPhone.replace(/\\D/g, '') + '@c.us';\n\nreturn {\n  json: {\n    chatId: chatId,\n    message: message,\n    leadId: lead.id,\n    leadName: leadName,\n    leadPhone: leadPhone,\n    appointmentId: appointment.appointmentId\n  }\n};"
      },
