      "id": "b7bd96c6-dfe1-4d33-8d41-d8bcf3a3b8ce",
      "name": "Get Reminder Config",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1152, -32],
