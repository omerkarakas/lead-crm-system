            }
          ]
        },
        "options": {}
      },
      "id": "1ee3ca2c-8787-437b-b97e-15d899d71eb1",
      "name": "Get Pending Appointments",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1600, -32],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "gLQzXXPOARPBtPqJ",
          "name": "Moka Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Filter appointments within reminder window\nconst window = $('Calculate Window').first().json;\nconst appointments = $('Get Pending Appointments').all();\n\nconst windowStart = new Date(window.windowStart);\nconst windowEnd = new Date(window.windowEnd);\n\nconst filteredAppointments = [];\n\nfor (const item of appointments) {\n  const appt = item.json;\n  const scheduledAt = new Date(appt.scheduled_at);\n  \n  // Check if appointment is within the reminder window\n  if (scheduledAt >= windowStart && scheduledAt <= windowEnd) {\n    filteredAppointments.push({\n      json: {\n        appointmentId: appt.id,\n        leadId: appt.lead_id,\n        scheduledAt: appt.scheduled_at,\n        durationMinutes: appt.duration_minutes,\n        meetingUrl: appt.meeting_url,\n        meetingType: appt.meeting_type\n      }\n    });\n  }\n}\n\n// If no appointments, return empty to stop flow\nif (filteredAppointments.length === 0) {\n  return [{ json: { noAppointments: true } }];\n}\n\nreturn filteredAppointments;"
      },
      "id": "3ad1019e-3876-47f8-b8a5-3b7b40e89759",
      "name": "Filter Appointments",
      "type": "n8n-nodes-base.code",
