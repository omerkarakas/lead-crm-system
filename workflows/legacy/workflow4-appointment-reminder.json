    {
      "parameters": {
        "jsCode": "// Calculate reminder window\nconst config = $('Get Reminder Config').first().json;\nconst env = $('ENV').first().json;\n\n// Get reminder hours from config or default\nconst reminderHours = parseInt(config.value) || parseInt(env.REMINDER_HOURS_BEFORE) || 24;\n\n// Current time in Istanbul timezone (scheduled_at is stored in Istanbul timezone)\nconst now = new Date();\n\n// Convert to Istanbul timezone string for comparison\nfunction toIstanbulISO(date) {\n  return date.toLocaleString('sv-SE', { timeZone: 'Europe/Istanbul' }).replace(' ', 'T') + '+03:00';\n}\n\n// Calculate window: appointments between now + reminderHours and now + reminderHours + 1\nconst windowStart = new Date(now.getTime() + (reminderHours * 60 * 60 * 1000));\nconst windowEnd = new Date(windowStart.getTime() + (60 * 60 * 1000)); // 1 hour window\n\nreturn {\n  json: {\n    reminderHours: reminderHours,\n    windowStart: toIstanbulISO(windowStart),\n    windowEnd: toIstanbulISO(windowEnd),\n    currentTime: toIstanbulISO(now)\n  }\n};"
      },
      "id": "52e60fdb-e043-4199-aa92-0fafbb55a9a4",
      "name": "Calculate Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1376, -32]
    },
    {
      "parameters": {
        "documentId": {
          "__rl": true,
          "value": "1yhU1LI11cJ2K8QA_CNjm_guodaA4qcwq_bCdgtswpKs",
